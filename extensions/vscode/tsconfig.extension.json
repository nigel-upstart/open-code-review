{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2021",
    "lib": ["ES2021"],
    "outDir": "out",
    "types": ["node", "vscode", "jest"]
  },
  "include": ["src/extension/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "out", "reference", "**/__tests__/**", "**/*.test.ts"]
}
