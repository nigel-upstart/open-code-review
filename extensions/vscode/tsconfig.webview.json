{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": []
  },
  "include": ["src/webview/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "out", "reference", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
